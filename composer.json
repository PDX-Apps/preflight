{
    "name": "pdxapps/preflight",
    "description": "A framework-agnostic, AI/CI-native runner for PHP code-quality tools (format, lint, static analysis, tests) in check or fix mode.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "ci",
        "static-analysis",
        "code-quality",
        "pint",
        "phpstan",
        "psalm",
        "rector",
        "phpcs",
        "phpmd",
        "preflight"
    ],
    "authors": [
        {
            "name": "Irving Gomez",
            "email": "gomirv.work@gmail.com"
        }
    ],
    "homepage": "https://github.com/PDX-Apps/preflight",
    "support": {
        "issues": "https://github.com/PDX-Apps/preflight/issues",
        "source": "https://github.com/PDX-Apps/preflight"
    },
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.4 || ^8.0",
        "symfony/process": "^7.4 || ^8.0"
    },
    "require-dev": {
        "brianium/paratest": "^7.0",
        "deptrac/deptrac": "^4",
        "laravel/pint": "^1.29",
        "phpmd/phpmd": "3.x-dev",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.0",
        "squizlabs/php_codesniffer": "^4.0",
        "vimeo/psalm": "^6.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "PdxApps\\Preflight\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PdxApps\\Preflight\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/preflight"
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
