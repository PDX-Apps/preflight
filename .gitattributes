# Keep the distributed package lean: exclude dev-only files from `composer install`
# dist archives. src/, bin/, stubs/, examples/, README, and LICENSE are kept.
/tests              export-ignore
/docs               export-ignore
/_planning          export-ignore
/.github            export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/phpunit.xml        export-ignore
/phpstan.neon       export-ignore
/psalm.xml          export-ignore
/phpcs.xml          export-ignore
/phpmd.xml          export-ignore
/rector.php         export-ignore
/pint.json          export-ignore
/deptrac.yaml       export-ignore
/preflight.php      export-ignore
